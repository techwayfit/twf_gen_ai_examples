@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="card shadow-lg">
    <div class="card-header @HeaderColorClass text-white py-3">
        <h5 class="mb-0">
    <i class="bi @HeaderIcon me-2"></i>
  @Title
 </h5>
      <small class="opacity-75">@Subtitle</small>
    </div>

    <div class="card-body p-0">
   <!-- Chat Messages -->
        <div class="chat-container p-3" style="height: 400px; overflow-y: auto; background-color: #f8f9fa;" @ref="chatContainer">
            @if (!messages.Any())
            {
   <div class="text-center text-muted mt-5">
 <i class="bi bi-chat-square-text" style="font-size: 2.5rem;"></i>
  <p class="mt-3">Start a conversation...</p>
     <small>@EmptyStateMessage</small>
           </div>
            }
         else
        {
@foreach (var msg in messages)
       {
    <div class="mb-3 @(msg.IsUser ? "text-end" : "")">
    <div class="d-inline-block @(msg.IsUser ? "bg-primary text-white" : "bg-white border") rounded shadow-sm px-3 py-2" 
          style="max-width: 85%; text-align: left;">
    
        @if (msg.IsUser)
     {
             <div class="user-message">@msg.Text</div>
         }
         else
            {
   <!-- Bot response with HTML rendering -->
            <div class="bot-message">
          @((MarkupString)FormatBotMessage(msg.Text))
          </div>
          
    @if (!string.IsNullOrEmpty(msg.ResponseType))
      {
  <div class="mt-2 pt-2 border-top">
    <small class="text-muted">
   <i class="bi @GetResponseIcon(msg.ResponseType) me-1"></i>
      <span class="badge @GetResponseBadgeClass(msg.ResponseType)">
   @msg.ResponseType
       </span>
     @if (!string.IsNullOrEmpty(msg.Sentiment))
   {
      <span class="ms-2">
       <i class="bi @GetSentimentIcon(msg.Sentiment) me-1"></i>
            @msg.Sentiment
       </span>
             }
 </small>
              </div>
            }
    }
  </div>
             <div class="small text-muted mt-1 @(msg.IsUser ? "text-end" : "")">
        <i class="bi bi-clock me-1"></i>
 @msg.Timestamp.ToLocalTime().ToString("HH:mm")
     </div>
    </div>
 }
         }

        @if (isLoading)
          {
            <div class="mb-3">
            <div class="d-inline-block bg-white border rounded shadow-sm px-3 py-2">
   <div class="spinner-border spinner-border-sm text-primary me-2" role="status">
 <span class="visually-hidden">Loading...</span>
         </div>
          <span class="text-muted">Typing...</span>
              </div>
     </div>
   }
  </div>

        <!-- Input Area -->
   <div class="border-top p-3 bg-white">
            <div class="input-group">
    <input type="text" 
             class="form-control" 
    placeholder="@InputPlaceholder"
     @bind="currentMessage"
                @bind:event="oninput"
        @onkeypress="HandleKeyPress"
        disabled="@isLoading" />
          <button class="btn @ButtonColorClass px-4" 
   @onclick="SendMessage" 
          disabled="@(isLoading || string.IsNullOrWhiteSpace(currentMessage))">
     <i class="bi bi-send-fill"></i>
 </button>
          </div>
        </div>

 @if (!string.IsNullOrEmpty(errorMessage))
        {
          <div class="alert alert-danger mx-3 mb-3" role="alert">
   <i class="bi bi-exclamation-triangle-fill me-2"></i>
                @errorMessage
        </div>
      }
    </div>
</div>

@if (ShowClearButton)
{
    <div class="mt-2 text-center">
        <button class="btn btn-outline-secondary btn-sm" @onclick="ClearChat">
   <i class="bi bi-trash"></i> Clear Chat
        </button>
  </div>
}

<style>
.chat-container {
     scroll-behavior: smooth;
 }

    .user-message {
    word-wrap: break-word;
    }

    .bot-message {
        word-wrap: break-word;
        line-height: 1.6;
    }

    .bot-message p {
        margin-bottom: 0.5rem;
    }

    .bot-message p:last-child {
        margin-bottom: 0;
  }

    .bot-message ul, .bot-message ol {
        margin-bottom: 0.5rem;
        padding-left: 1.5rem;
    }

    .bot-message li {
        margin-bottom: 0.25rem;
    }

    .bot-message strong {
 font-weight: 600;
        color: #212529;
    }

    .bot-message em {
  font-style: italic;
  }

    .bot-message code {
  background-color: #f8f9fa;
        padding: 0.2rem 0.4rem;
        border-radius: 3px;
        font-family: 'Courier New', monospace;
        font-size: 0.9em;
    }

    .bot-message pre {
      background-color: #f8f9fa;
        padding: 0.5rem;
        border-radius: 5px;
    overflow-x: auto;
    }

    .bot-message a {
        color: #0d6efd;
        text-decoration: underline;
    }
</style>

@code {
    [Parameter] public string Title { get; set; } = "Customer Support";
    [Parameter] public string Subtitle { get; set; } = "How can we help you today?";
    [Parameter] public string HeaderIcon { get; set; } = "bi-headset";
  [Parameter] public string HeaderColorClass { get; set; } = "bg-primary";
    [Parameter] public string ButtonColorClass { get; set; } = "btn-primary";
    [Parameter] public string InputPlaceholder { get; set; } = "Type your message...";
    [Parameter] public string EmptyStateMessage { get; set; } = "Ask me anything about our products or services";
    [Parameter] public bool ShowClearButton { get; set; } = true;
    [Parameter] public string BotType { get; set; } = "support";

    private ElementReference chatContainer;
    private List<ChatMessage> messages = new();
    private string currentMessage = string.Empty;
  private string? sessionId;
    private bool isLoading = false;
    private string? errorMessage;

    private class ChatMessage
    {
public string Text { get; set; } = string.Empty;
        public bool IsUser { get; set; }
        public DateTime Timestamp { get; set; }
        public string? ResponseType { get; set; }
        public string? Sentiment { get; set; }
    }

    private string FormatBotMessage(string message)
    {
      if (string.IsNullOrEmpty(message)) return message;

  // Convert markdown-like formatting to HTML
        var formatted = message;

        // Convert **bold** to <strong>
      formatted = System.Text.RegularExpressions.Regex.Replace(
       formatted, 
    @"\*\*(.+?)\*\*", 
   "<strong>$1</strong>");

        // Convert *italic* to <em>
        formatted = System.Text.RegularExpressions.Regex.Replace(
      formatted, 
       @"\*(.+?)\*", 
            "<em>$1</em>");

    // Convert line breaks to <br>
        formatted = formatted.Replace("\n\n", "</p><p>");
     formatted = formatted.Replace("\n", "<br>");

        // Wrap in paragraph tags if not already
        if (!formatted.StartsWith("<p>"))
      {
            formatted = "<p>" + formatted + "</p>";
    }

        // Convert numbered lists
        formatted = System.Text.RegularExpressions.Regex.Replace(
          formatted,
         @"(<br>|^)(\d+\.)\s*(.+?)(<br>|$)",
       m => $"<li>{m.Groups[3].Value}</li>");

        // Wrap list items in <ol>
        if (formatted.Contains("<li>"))
        {
            formatted = System.Text.RegularExpressions.Regex.Replace(
           formatted,
        @"(<li>.*?</li>)+",
             m => $"<ol>{m.Value}</ol>");
        }

  // Convert bullet points
   formatted = System.Text.RegularExpressions.Regex.Replace(
            formatted,
   @"(<br>|^)[-•]\s*(.+?)(<br>|$)",
            m => $"<li>{m.Groups[2].Value}</li>");

        // Clean up extra paragraph tags
        formatted = formatted.Replace("<p></p>", "");
        formatted = formatted.Replace("<p><br>", "<p>");
        formatted = formatted.Replace("<br></p>", "</p>");

      return formatted;
    }

    private string GetResponseIcon(string? responseType)
    {
        return responseType?.ToLower() switch
        {
   "escalation" => "bi-exclamation-circle",
       "standard" => "bi-check-circle",
    "rejected" => "bi-x-circle",
            _ => "bi-info-circle"
    };
    }

    private string GetResponseBadgeClass(string? responseType)
{
        return responseType?.ToLower() switch
    {
    "escalation" => "bg-warning",
    "standard" => "bg-success",
         "rejected" => "bg-danger",
            _ => "bg-secondary"
        };
    }

    private string GetSentimentIcon(string? sentiment)
    {
   return sentiment?.ToLower() switch
        {
      "positive" => "bi-emoji-smile",
            "neutral" => "bi-emoji-neutral",
     "negative" => "bi-emoji-frown",
            "angry" => "bi-emoji-angry",
   _ => "bi-emoji-neutral"
        };
    }

 private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(currentMessage)) return;

        var userMessage = currentMessage.Trim();
        currentMessage = string.Empty;
    errorMessage = null;

        // Add user message
   messages.Add(new ChatMessage
      {
            Text = userMessage,
          IsUser = true,
         Timestamp = DateTime.UtcNow
        });

 isLoading = true;
        StateHasChanged();

        try
        {
   var baseUrl = Navigation.BaseUri.TrimEnd('/');
         var response = await Http.PostAsJsonAsync($"{baseUrl}/api/ChatApi/message", new
      {
     SessionId = sessionId,
      Message = userMessage,
 BotType = BotType
        });

            if (response.IsSuccessStatusCode)
        {
        var result = await response.Content.ReadFromJsonAsync<ChatApiResponse>();
  if (result != null)
          {
              sessionId = result.SessionId;
       
     messages.Add(new ChatMessage
        {
          Text = result.Message,
          IsUser = false,
     Timestamp = result.Timestamp,
                  ResponseType = result.ResponseType,
  Sentiment = result.Sentiment
            });
     }
    }
            else
     {
                errorMessage = "Failed to get response. Please try again.";
            }
        }
   catch (Exception ex)
   {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
    isLoading = false;
            StateHasChanged();
    }
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(currentMessage))
        {
            await SendMessage();
     }
}

    private async Task ClearChat()
    {
        if (!string.IsNullOrEmpty(sessionId))
      {
          try
     {
 var baseUrl = Navigation.BaseUri.TrimEnd('/');
                await Http.DeleteAsync($"{baseUrl}/api/ChatApi/session/{sessionId}");
            }
    catch { /* Ignore errors */ }
}

      messages.Clear();
        sessionId = null;
        currentMessage = string.Empty;
    errorMessage = null;
        StateHasChanged();
  }

    private class ChatApiResponse
    {
        public string SessionId { get; set; } = string.Empty;
        public string Message { get; set; } = string.Empty;
        public string ResponseType { get; set; } = string.Empty;
        public string? Sentiment { get; set; }
    public DateTime Timestamp { get; set; }
    }
}
