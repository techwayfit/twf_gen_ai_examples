@page "/"

<PageTitle>SEO Content Writer</PageTitle>

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-12 text-center">
            <h2 class="display-5">Long-Form Content Writer with SEO Optimisation</h2>
            <p class="text-muted">
                Research-grounded article generation — competitor analysis, structured outlining,
                full draft, and metadata in one pipeline
            </p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-12">
            <ContentWriterWidget />
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-12">
            <div class="alert alert-info" role="alert">
                <h5 class="alert-heading"><i class="bi bi-info-circle me-2"></i>About This Demo</h5>
                <p class="mb-0">
                    This pipeline runs four sequential stages: <strong>competitor research</strong> via the Serper.dev search API,
                    <strong>SEO outline generation</strong> with H2/H3 planning and FAQ ideas,
                    <strong>long-form article drafting</strong> streamed live to your screen, and
                    <strong>metadata generation</strong> including meta description and title variants.
                    Each stage has a clear responsibility, making the output reviewable and editable at every step.
                </p>
            </div>
        </div>
    </div>
</div>
