@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Navigation
@using System.Text.Json
@using Markdig

<!-- ══ BRIEF FORM CARD ══════════════════════════════════════════════════════ -->
<div class="card shadow-lg mb-4">
    <div class="card-header bg-primary text-white py-3">
        <h5 class="mb-0">
            <i class="bi bi-pencil-square me-2"></i>Content Brief
        </h5>
        <small class="opacity-75">Fill in your keyword and audience details, then generate</small>
    </div>

    <div class="card-body">
        <div class="row g-3">
            <!-- Primary keyword -->
            <div class="col-md-6">
                <label class="form-label fw-semibold">
                    Primary Keyword <span class="text-danger">*</span>
                </label>
                <input type="text"
                       class="form-control"
                       placeholder="e.g. best AI note-taking apps"
                       @bind="primaryKeyword"
                       @bind:event="oninput"
                       disabled="@isGenerating"
                       maxlength="200" />
                <div class="d-flex justify-content-between mt-1">
                    <small class="text-muted">@primaryKeyword.Length / 200</small>
                </div>
            </div>

            <!-- Secondary keywords -->
            <div class="col-md-6">
                <label class="form-label fw-semibold">Secondary Keywords</label>
                <input type="text"
                       class="form-control"
                       placeholder="e.g. meeting transcription, team notes"
                       @bind="secondaryKeywords"
                       disabled="@isGenerating" />
                <small class="text-muted">Comma-separated, optional</small>
            </div>

            <!-- Target audience -->
            <div class="col-md-6">
                <label class="form-label fw-semibold">Target Audience</label>
                <input type="text"
                       class="form-control"
                       placeholder="e.g. operations managers at SaaS companies"
                       @bind="targetAudience"
                       disabled="@isGenerating" />
            </div>

            <!-- Tone -->
            <div class="col-md-3">
                <label class="form-label fw-semibold">Tone</label>
                <select class="form-select" @bind="tone" disabled="@isGenerating">
                    @foreach (var t in Tones)
                    {
                        <option value="@t.Key">@t.Value</option>
                    }
                </select>
            </div>

            <!-- Word count -->
            <div class="col-md-3">
                <label class="form-label fw-semibold">Target Word Count</label>
                <select class="form-select" @bind="targetWordCount" disabled="@isGenerating">
                    <option value="1200">~1,200 words</option>
                    <option value="1500">~1,500 words</option>
                    <option value="1800">~1,800 words</option>
                    <option value="2500">~2,500 words</option>
                </select>
            </div>

            <!-- Search intent -->
            <div class="col-md-4">
                <label class="form-label fw-semibold">Search Intent</label>
                <select class="form-select" @bind="searchIntent" disabled="@isGenerating">
                    <option value="informational">Informational</option>
                    <option value="commercial investigation">Commercial Investigation</option>
                    <option value="transactional">Transactional</option>
                    <option value="navigational">Navigational</option>
                </select>
            </div>

            <!-- Call to action -->
            <div class="col-md-8">
                <label class="form-label fw-semibold">Call to Action</label>
                <input type="text"
                       class="form-control"
                       placeholder="e.g. start a free trial, book a demo"
                       @bind="callToAction"
                       disabled="@isGenerating" />
            </div>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button class="btn btn-primary px-4"
                    @onclick="Generate"
                    disabled="@(isGenerating || string.IsNullOrWhiteSpace(primaryKeyword))">
                @if (isGenerating)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    <span>Generating...</span>
                }
                else
                {
                    <i class="bi bi-lightning-charge-fill me-2"></i>
                    <span>Generate Article</span>
                }
            </button>
            <button class="btn btn-outline-secondary" @onclick="Reset" disabled="@isGenerating">
                <i class="bi bi-arrow-counterclockwise me-1"></i>Reset
            </button>
        </div>
    </div>
</div>

<!-- ══ ERROR BANNER ════════════════════════════════════════════════════════ -->
@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMessage
    </div>
}

<!-- ══ STAGE PROGRESS ══════════════════════════════════════════════════════ -->
@if (isGenerating || stages.Count > 0)
{
    <div class="card shadow-sm mb-4">
        <div class="card-body py-3">
            <div class="d-flex gap-2 flex-wrap align-items-center">
                @foreach (var (msg, idx, done) in stages)
                {
                    <span class="badge @(done ? "bg-success" : "bg-primary") stage-badge">
                        @if (done)
                        {
                            <i class="bi bi-check-circle me-1"></i>
                        }
                        else
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        }
                        @msg
                    </span>
                    @if (idx < 4)
                    {
                        <i class="bi bi-arrow-right text-muted"></i>
                    }
                }
            </div>
        </div>
    </div>
}

<!-- ══ OUTLINE PANEL ═══════════════════════════════════════════════════════ -->
@if (outlineData != null)
{
    <div class="card shadow-sm mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-list-ul me-2 text-primary"></i><strong>Generated Outline</strong></span>
            <div>
                @if (!string.IsNullOrWhiteSpace(outlineData.Slug))
                {
                    <span class="badge bg-secondary me-2">
                        <i class="bi bi-link-45deg me-1"></i>/@outlineData.Slug
                    </span>
                }
            </div>
        </div>
        <div class="card-body">
            @if (!string.IsNullOrWhiteSpace(outlineData.SeoTitle))
            {
                <p class="fw-semibold mb-2">
                    <i class="bi bi-hash text-primary me-1"></i>@outlineData.SeoTitle
                </p>
            }
            <ul class="list-unstyled mb-0">
                @foreach (var outlineSection in outlineData.OutlineSections)
                {
                    var isH3 = outlineSection.StartsWith("H3:", StringComparison.OrdinalIgnoreCase);
                    <li class="@(isH3 ? "ms-4 text-muted" : "fw-semibold") mb-1">
                        <i class="bi @(isH3 ? "bi-chevron-right" : "bi-dash-lg") me-1 text-primary"></i>
                        @outlineSection.Replace("H2: ", "").Replace("H3: ", "")
                    </li>
                }
            </ul>

            @if (outlineData.FaqIdeas.Count > 0)
            {
                <details class="mt-3">
                    <summary class="text-muted" style="cursor:pointer">
                        <i class="bi bi-question-circle me-1"></i>@outlineData.FaqIdeas.Count FAQ ideas
                    </summary>
                    <ul class="list-unstyled mt-2 ms-3">
                        @foreach (var q in outlineData.FaqIdeas)
                        {
                            <li class="text-secondary mb-1"><i class="bi bi-chat-dots me-1"></i>@q</li>
                        }
                    </ul>
                </details>
            }
        </div>
    </div>
}

<!-- ══ DRAFT / RESULTS PANEL ═══════════════════════════════════════════════ -->
@if (isStreaming || contentPackage != null)
{
    <div class="card shadow-lg">
        <div class="card-header bg-success text-white py-3 d-flex justify-content-between align-items-center">
            <span>
                <i class="bi bi-file-earmark-text me-2"></i>
                <strong>@(contentPackage?.SeoTitle ?? "Generating Article...")</strong>
            </span>
            @if (contentPackage != null)
            {
                <small class="opacity-75">
                    <i class="bi bi-clock me-1"></i>@contentPackage.GeneratedAt.ToLocalTime().ToString("HH:mm:ss")
                </small>
            }
        </div>

        @if (contentPackage != null)
        {
            <!-- Result tabs -->
            <div class="card-body p-0">
                <ul class="nav nav-tabs px-3 pt-2" id="resultTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link @(activeTab == "article" ? "active" : "")"
                                @onclick='() => activeTab = "article"' type="button">
                            <i class="bi bi-file-text me-1"></i>Article
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link @(activeTab == "seo" ? "active" : "")"
                                @onclick='() => activeTab = "seo"' type="button">
                            <i class="bi bi-search me-1"></i>SEO Metadata
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link @(activeTab == "raw" ? "active" : "")"
                                @onclick='() => activeTab = "raw"' type="button">
                            <i class="bi bi-code me-1"></i>Raw Markdown
                        </button>
                    </li>
                </ul>

                <div class="tab-content p-3">
                    <!-- Article tab -->
                    @if (activeTab == "article")
                    {
                        <div class="article-preview">
                            @((MarkupString)RenderMarkdown(contentPackage.ArticleMarkdown))
                        </div>
                    }

                    <!-- SEO Metadata tab -->
                    @if (activeTab == "seo")
                    {
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label fw-semibold text-muted small">META DESCRIPTION</label>
                                <div class="bg-light rounded p-3 border">
                                    <p class="mb-1">@contentPackage.MetaDescription</p>
                                    <small class="text-muted">
                                        @contentPackage.MetaDescription.Length chars
                                        @(contentPackage.MetaDescription.Length is >= 145 and <= 160
                                            ? "(optimal)" : contentPackage.MetaDescription.Length < 145
                                                ? "(too short)" : "(too long)")
                                    </small>
                                </div>
                            </div>

                            @if (contentPackage.TitleVariants.Count > 0)
                            {
                                <div class="col-12">
                                    <label class="form-label fw-semibold text-muted small">TITLE VARIANTS</label>
                                    @foreach (var variant in contentPackage.TitleVariants)
                                    {
                                        <div class="bg-light rounded p-2 border mb-2">
                                            <i class="bi bi-type me-2 text-primary"></i>@variant
                                        </div>
                                    }
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(contentPackage.SocialPreview))
                            {
                                <div class="col-12">
                                    <label class="form-label fw-semibold text-muted small">SOCIAL PREVIEW</label>
                                    <div class="bg-light rounded p-3 border">
                                        <i class="bi bi-share me-2 text-primary"></i>@contentPackage.SocialPreview
                                    </div>
                                </div>
                            }

                            <div class="col-12">
                                <label class="form-label fw-semibold text-muted small">URL SLUG</label>
                                <div class="bg-light rounded p-2 border font-monospace">
                                    /@contentPackage.Slug
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Raw Markdown tab -->
                    @if (activeTab == "raw")
                    {
                        <div class="position-relative">
                            <button class="btn btn-sm btn-outline-secondary position-absolute top-0 end-0 m-2"
                                    @onclick="CopyMarkdown">
                                <i class="bi bi-clipboard me-1"></i>Copy
                            </button>
                            <pre class="raw-markdown border rounded p-3 bg-light"><code>@contentPackage.ArticleMarkdown</code></pre>
                        </div>
                    }
                </div>
            </div>
        }
        else if (isStreaming)
        {
            <!-- Live streaming view -->
            <div class="card-body">
                <div class="article-preview streaming-content">
                    @((MarkupString)RenderMarkdown(streamingArticle))
                    <span class="blinking-cursor">|</span>
                </div>
            </div>
        }
    </div>
}

<style>
    .stage-badge {
        font-size: 0.8rem;
        padding: 0.4em 0.75em;
    }

    .article-preview {
        line-height: 1.8;
        font-size: 1rem;
        max-width: 820px;
    }

    .article-preview ::deep h1 { font-size: 1.75rem; margin-top: 1.5rem; }
    .article-preview ::deep h2 { font-size: 1.35rem; margin-top: 1.5rem; border-bottom: 1px solid #dee2e6; padding-bottom: 0.3rem; }
    .article-preview ::deep h3 { font-size: 1.1rem; margin-top: 1.2rem; color: #495057; }
    .article-preview ::deep p  { margin-bottom: 1rem; }
    .article-preview ::deep ul, .article-preview ::deep ol { margin-bottom: 1rem; padding-left: 1.5rem; }
    .article-preview ::deep li { margin-bottom: 0.35rem; }
    .article-preview ::deep strong { font-weight: 600; }

    .streaming-content {
        min-height: 200px;
    }

    .raw-markdown {
        white-space: pre-wrap;
        word-wrap: break-word;
        font-size: 0.82rem;
        max-height: 600px;
        overflow-y: auto;
    }

    .article-preview ::deep pre {
        background: #f6f8fa;
        border: 1px solid #d0d7de;
        border-radius: 6px;
        padding: 1rem 1.25rem;
        margin: 1rem 0;
        overflow-x: auto;
        font-size: 0.85rem;
        line-height: 1.6;
    }

    .article-preview ::deep code {
        font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace;
        font-size: 0.85em;
        background: #f6f8fa;
        border: 1px solid #d0d7de;
        border-radius: 3px;
        padding: 0.1em 0.4em;
    }

    .article-preview ::deep pre code {
        background: none;
        border: none;
        padding: 0;
        font-size: inherit;
    }

    .blinking-cursor {
        display: inline-block;
        font-weight: 100;
        color: #0d6efd;
        animation: blink 0.8s step-end infinite;
    }

    @@keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
    }
</style>

@code {
    // ── Form fields ──────────────────────────────────────────────────────────
    private string primaryKeyword    = string.Empty;
    private string secondaryKeywords = string.Empty;
    private string targetAudience    = string.Empty;
    private string tone              = "expert and authoritative";
    private int    targetWordCount   = 1500;
    private string searchIntent      = "informational";
    private string callToAction      = string.Empty;

    // ── State ────────────────────────────────────────────────────────────────
    private bool   isGenerating  = false;
    private bool   isStreaming   = false;
    private string errorMessage  = string.Empty;
    private string activeTab     = "article";

    // Stage progress: (message, index, isDone)
    private List<(string Msg, int Idx, bool Done)> stages = new();

    // Intermediate and final data
    private OutlinePayload?     outlineData     = null;
    private string              streamingArticle = string.Empty;
    private ContentPackagePayload? contentPackage = null;

    private static readonly Dictionary<string, string> Tones = new()
    {
        { "expert and authoritative", "Expert & Authoritative" },
        { "friendly and conversational", "Friendly & Conversational" },
        { "practical and actionable", "Practical & Actionable" },
        { "formal and professional", "Formal & Professional" }
    };

    // ── Generate ─────────────────────────────────────────────────────────────
    private async Task Generate()
    {
        if (string.IsNullOrWhiteSpace(primaryKeyword)) return;

        isGenerating    = true;
        isStreaming     = false;
        errorMessage    = string.Empty;
        streamingArticle = string.Empty;
        outlineData     = null;
        contentPackage  = null;
        stages          = new();
        activeTab       = "article";
        await InvokeAsync(StateHasChanged);

        try
        {
            var baseUrl    = Navigation.BaseUri.TrimEnd('/');
            var requestMsg = new HttpRequestMessage(HttpMethod.Post,
                $"{baseUrl}/api/ContentWriter/generate");

            requestMsg.Content = JsonContent.Create(new
            {
                PrimaryKeyword    = primaryKeyword.Trim(),
                SecondaryKeywords = secondaryKeywords.Trim(),
                TargetAudience    = targetAudience.Trim(),
                SearchIntent      = searchIntent,
                Tone              = tone,
                TargetWordCount   = targetWordCount,
                CallToAction      = callToAction.Trim()
            });

            using var response = await Http.SendAsync(requestMsg,
                HttpCompletionOption.ResponseHeadersRead);

            using var stream = await response.Content.ReadAsStreamAsync();
            using var reader = new System.IO.StreamReader(stream);

            var jsonOpts       = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            string? pendingEvt = null;

            while (!reader.EndOfStream)
            {
                var line = await reader.ReadLineAsync();
                if (line == null) break;

                if (line.StartsWith("event: "))
                {
                    pendingEvt = line[7..].Trim();
                }
                else if (line.StartsWith("data: "))
                {
                    var data = line[6..];

                    switch (pendingEvt)
                    {
                        case "stage":
                            var stageEvt = JsonSerializer.Deserialize<StageEventPayload>(data, jsonOpts);
                            if (stageEvt != null)
                            {
                                // Mark any prior stage as done
                                for (int i = 0; i < stages.Count; i++)
                                    stages[i] = (stages[i].Msg, stages[i].Idx, true);

                                stages.Add((stageEvt.Message, stageEvt.StageIndex, false));
                            }
                            await InvokeAsync(StateHasChanged);
                            break;

                        case "outline":
                            outlineData = JsonSerializer.Deserialize<OutlinePayload>(data, jsonOpts);
                            await InvokeAsync(StateHasChanged);
                            break;

                        case "chunk":
                            var chunk = JsonSerializer.Deserialize<ChunkPayload>(data, jsonOpts);
                            if (chunk != null)
                            {
                                isStreaming      = true;
                                streamingArticle += chunk.Delta;
                                await InvokeAsync(StateHasChanged);
                            }
                            break;

                        case "complete":
                            contentPackage  = JsonSerializer.Deserialize<ContentPackagePayload>(data, jsonOpts);
                            isStreaming     = false;
                            streamingArticle = string.Empty;

                            // Mark all stages done
                            for (int i = 0; i < stages.Count; i++)
                                stages[i] = (stages[i].Msg, stages[i].Idx, true);

                            await InvokeAsync(StateHasChanged);
                            break;

                        case "error":
                            var errPayload  = JsonSerializer.Deserialize<ErrorPayload>(data, jsonOpts);
                            errorMessage    = errPayload?.Error ?? "Generation failed.";
                            isStreaming     = false;
                            await InvokeAsync(StateHasChanged);
                            break;
                    }

                    pendingEvt = null;
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isGenerating = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    // ── Reset ────────────────────────────────────────────────────────────────
    private void Reset()
    {
        primaryKeyword    = string.Empty;
        secondaryKeywords = string.Empty;
        targetAudience    = string.Empty;
        tone              = "expert and authoritative";
        targetWordCount   = 1500;
        searchIntent      = "informational";
        callToAction      = string.Empty;
        errorMessage      = string.Empty;
        streamingArticle   = string.Empty;
        outlineData       = null;
        contentPackage    = null;
        stages            = new();
        isStreaming       = false;
        StateHasChanged();
    }

    // ── Copy markdown ────────────────────────────────────────────────────────
    private void CopyMarkdown()
    {
        // Clipboard access via JS interop would be needed for a real copy;
        // for this demo we just switch to raw tab as a visual affordance.
        activeTab = "raw";
        StateHasChanged();
    }

    // ── Markdown → HTML (Markdig) ────────────────────────────────────────────
    private static readonly Markdig.MarkdownPipeline _mdPipeline =
        new Markdig.MarkdownPipelineBuilder()
            .UseAdvancedExtensions()
            .Build();

    private static string RenderMarkdown(string md) =>
        string.IsNullOrWhiteSpace(md)
            ? string.Empty
            : Markdig.Markdown.ToHtml(md, _mdPipeline);

    // ── SSE payload types ────────────────────────────────────────────────────
    private class StageEventPayload
    {
        public string Message    { get; set; } = string.Empty;
        public int    StageIndex { get; set; }
        public int    TotalStages { get; set; }
    }

    private class OutlinePayload
    {
        public string       SeoTitle        { get; set; } = string.Empty;
        public string       Slug            { get; set; } = string.Empty;
        public List<string> OutlineSections { get; set; } = new();
        public List<string> FaqIdeas        { get; set; } = new();
    }

    private class ChunkPayload
    {
        public string Delta { get; set; } = string.Empty;
    }

    private class ContentPackagePayload
    {
        public string       PrimaryKeyword   { get; set; } = string.Empty;
        public string       SeoTitle         { get; set; } = string.Empty;
        public string       Slug             { get; set; } = string.Empty;
        public List<string> OutlineSections  { get; set; } = new();
        public List<string> FaqIdeas         { get; set; } = new();
        public string       ArticleMarkdown  { get; set; } = string.Empty;
        public string       MetaDescription  { get; set; } = string.Empty;
        public List<string> TitleVariants    { get; set; } = new();
        public string       SocialPreview    { get; set; } = string.Empty;
        public DateTime     GeneratedAt      { get; set; }
    }

    private class ErrorPayload
    {
        public string Error { get; set; } = string.Empty;
    }
}
