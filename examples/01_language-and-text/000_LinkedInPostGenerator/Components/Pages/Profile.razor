@page "/profile"
@rendermode InteractiveServer
@inject HttpClient Http
@inject NavigationManager Navigation
@using System.Text.Json

<PageTitle>My Profile — LinkedIn Post Generator</PageTitle>

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="display-6">
                <i class="bi bi-person-gear me-2 text-primary"></i>My Author Profile
            </h2>
            <p class="text-muted">
                This profile is loaded as the system prompt for every post you generate.
                Keeping it up to date ensures every post sounds like you.
            </p>
        </div>
    </div>

    <!-- Error / success banners -->
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger alert-dismissible" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMessage
            <button type="button" class="btn-close" @onclick="() => errorMessage = string.Empty"></button>
        </div>
    }
    @if (saved)
    {
        <div class="alert alert-success alert-dismissible" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>Profile saved successfully.
            <button type="button" class="btn-close" @onclick="() => saved = false"></button>
        </div>
    }

    @if (isLoading)
    {
        <div class="text-center py-5">
            <span class="spinner-border text-primary" role="status"></span>
            <p class="text-muted mt-3">Loading profile...</p>
        </div>
    }
    else
    {
        <div class="row g-4">

            <!-- ── Left column ──────────────────────────────────────────────── -->
            <div class="col-12 col-lg-6">

                <!-- Bio -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header fw-semibold">
                        <i class="bi bi-person-lines-fill me-2 text-primary"></i>Author Bio
                    </div>
                    <div class="card-body">
                        <label class="form-label text-muted small">
                            Who you are, your background, what you care about professionally.
                            This is injected into every post's system prompt.
                        </label>
                        <textarea class="form-control"
                                  rows="6"
                                  placeholder="e.g. Senior software engineer at a fintech startup. 10 years building distributed systems. Passionate about reliability engineering and developer experience."
                                  @bind="profile.MyProfile"
                                  @bind:event="oninput"></textarea>
                        <small class="text-muted">@profile.MyProfile.Length characters</small>
                    </div>
                </div>

                <!-- Writing guidelines -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header fw-semibold">
                        <i class="bi bi-pencil-fill me-2 text-primary"></i>Writing Guidelines
                    </div>
                    <div class="card-body">
                        <label class="form-label text-muted small">
                            Style rules applied to every post. Be specific — vague instructions produce generic posts.
                        </label>
                        <textarea class="form-control"
                                  rows="6"
                                  placeholder="e.g. Write in first person. Be specific and concrete. Avoid corporate buzzwords. Use short paragraphs of 1–3 lines. Start with a bold statement or question. End with a call to action."
                                  @bind="profile.WritingGuidelines"
                                  @bind:event="oninput"></textarea>
                        <small class="text-muted">@profile.WritingGuidelines.Length characters</small>
                    </div>
                </div>
            </div>

            <!-- ── Right column ─────────────────────────────────────────────── -->
            <div class="col-12 col-lg-6">

                <!-- Previous post references -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-collection me-2 text-primary"></i>Previous Post References</span>
                        <button class="btn btn-sm btn-outline-primary" @onclick="AddReference">
                            <i class="bi bi-plus-lg me-1"></i>Add
                        </button>
                    </div>
                    <div class="card-body">
                        <p class="text-muted small mb-3">
                            Add titles, excerpts, or URLs from past posts. The model uses these to mirror your tone and style.
                        </p>
                        @if (profile.PreviousPostReferences.Count == 0)
                        {
                            <p class="text-muted fst-italic small">No references yet. Click Add to add one.</p>
                        }
                        else
                        {
                            @for (int i = 0; i < profile.PreviousPostReferences.Count; i++)
                            {
                                var idx = i;
                                <div class="input-group mb-2">
                                    <input type="text"
                                           class="form-control form-control-sm"
                                           placeholder="Post title, excerpt, or URL"
                                           value="@profile.PreviousPostReferences[idx]"
                                           @oninput="e => profile.PreviousPostReferences[idx] = e.Value?.ToString() ?? string.Empty" />
                                    <button class="btn btn-outline-danger btn-sm"
                                            @onclick="() => RemoveReference(idx)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            }
                        }
                    </div>
                </div>

                <!-- Defaults -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header fw-semibold">
                        <i class="bi bi-sliders me-2 text-primary"></i>Default Settings
                    </div>
                    <div class="card-body">
                        <p class="text-muted small mb-3">
                            These values pre-fill the generator form. You can still change them per post.
                        </p>

                        <div class="mb-3">
                            <label class="form-label fw-semibold small">Default Role</label>
                            <select class="form-select form-select-sm" @bind="profile.DefaultRole">
                                @foreach (var r in Constants.Roles.All)
                                {
                                    <option value="@r">@FormatLabel(r)</option>
                                }
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold small">Default Audience</label>
                            <select class="form-select form-select-sm" @bind="profile.DefaultAudience">
                                @foreach (var a in Constants.Audiences.All)
                                {
                                    <option value="@a">@FormatLabel(a)</option>
                                }
                            </select>
                        </div>

                        <div class="mb-0">
                            <label class="form-label fw-semibold small">Default Max Length</label>
                            <select class="form-select form-select-sm" @bind="profile.DefaultMaxChars">
                                <option value="600">600 — short</option>
                                <option value="900">900 — medium</option>
                                <option value="1300">1,300 — standard</option>
                                <option value="1800">1,800 — long-form</option>
                                <option value="2500">2,500 — detailed</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Save button -->
                <div class="d-flex justify-content-end">
                    <button class="btn btn-primary px-5"
                            @onclick="SaveProfile"
                            disabled="@isSaving">
                        @if (isSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            <span>Saving...</span>
                        }
                        else
                        {
                            <i class="bi bi-floppy me-2"></i>
                            <span>Save Profile</span>
                        }
                    </button>
                </div>
            </div>

        </div>
    }
</div>

@code {
    private ProfileModel profile  = new();
    private bool         isLoading = true;
    private bool         isSaving  = false;
    private bool         saved     = false;
    private string       errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var baseUrl  = Navigation.BaseUri.TrimEnd('/');
            var loaded   = await Http.GetFromJsonAsync<ProfileModel>($"{baseUrl}/api/Post/profile");
            if (loaded != null) profile = loaded;
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load profile: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveProfile()
    {
        isSaving     = true;
        errorMessage = string.Empty;
        saved        = false;

        try
        {
            var baseUrl  = Navigation.BaseUri.TrimEnd('/');
            var response = await Http.PutAsJsonAsync($"{baseUrl}/api/Post/profile", profile);
            if (response.IsSuccessStatusCode)
                saved = true;
            else
                errorMessage = "Save failed. Please try again.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void AddReference() =>
        profile.PreviousPostReferences.Add(string.Empty);

    private void RemoveReference(int idx) =>
        profile.PreviousPostReferences.RemoveAt(idx);

    private static string FormatLabel(string value) =>
        System.Globalization.CultureInfo.InvariantCulture.TextInfo
            .ToTitleCase(value.Replace('-', ' ').ToLower());

    private class ProfileModel
    {
        public string       MyProfile               { get; set; } = string.Empty;
        public string       WritingGuidelines        { get; set; } = string.Empty;
        public List<string> PreviousPostReferences   { get; set; } = new();
        public string       DefaultRole              { get; set; } = "developer";
        public string       DefaultAudience          { get; set; } = "engineers";
        public int          DefaultMaxChars          { get; set; } = 1300;
    }
}
